<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Emerald Green - Light -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#66BB6A"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1B5E20"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#43A047"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#C8E6C9"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#388E3C"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#E8F5E9"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#C8E6C9"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DarkInputBrush" Color="#F1F8E9"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B5E20"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#81C784"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="#66BB6A"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#43A047"/>
    <SolidColorBrush x:Key="SelectionTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F9A825"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#388E3C"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#2E7D32"/>
</ResourceDictionary>
