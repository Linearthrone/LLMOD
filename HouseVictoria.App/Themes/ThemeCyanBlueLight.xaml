<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Cyan/Blue - Light -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0097A7"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#4DD0E1"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#006064"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#00BCD4"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#B2EBF2"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#00838F"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#E0F7FA"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#B2EBF2"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DarkInputBrush" Color="#F1F8E9"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#006064"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#00838F"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#80CBC4"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="#4DB6AC"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#00BCD4"/>
    <SolidColorBrush x:Key="SelectionTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F9A825"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#388E3C"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#0097A7"/>
</ResourceDictionary>
