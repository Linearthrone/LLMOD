<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Amber/Orange - Light -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF8F00"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#FFB300"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#E65100"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FFA000"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFE082"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#FF6F00"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#FFF8E1"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#FFECB3"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DarkInputBrush" Color="#FFFDE7"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E65100"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF8F00"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#FFCC80"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="#FFB300"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#FFA000"/>
    <SolidColorBrush x:Key="SelectionTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F9A825"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#388E3C"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#FF8F00"/>
</ResourceDictionary>
