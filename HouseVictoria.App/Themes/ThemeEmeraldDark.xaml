<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Emerald Green - Dark -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#00E676"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#69F0AE"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#00C853"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#76FF03"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#B9F6CA"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#64DD17"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#0A1F0A"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#142E14"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="#1A3D1A"/>
    <SolidColorBrush x:Key="DarkInputBrush" Color="#254A25"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8F5E9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A5D6A7"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#4A5F4A"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="#5A6F5A"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#00E676"/>
    <SolidColorBrush x:Key="SelectionTextBrush" Color="#0A1F0A"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFD740"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#69F0AE"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#00E676"/>
</ResourceDictionary>
