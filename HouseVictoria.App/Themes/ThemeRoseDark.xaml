<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Rose/Pink - Dark -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#F48FB1"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#F8BBD9"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#EC407A"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF80AB"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFB2DD"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#FF4081"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#1F0A12"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#2E141A"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="#3D1A25"/>
    <SolidColorBrush x:Key="DarkInputBrush" Color="#4A2530"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FCE4EC"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#F8BBD9"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#5F4A52"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="#6F5A62"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#F48FB1"/>
    <SolidColorBrush x:Key="SelectionTextBrush" Color="#1F0A12"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFD740"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#69F0AE"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#F48FB1"/>
</ResourceDictionary>
