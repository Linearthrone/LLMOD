<Window x:Class="HouseVictoria.App.Screens.Windows.EditSystemPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit System Prompt" Height="880" Width="720" MinHeight="680" MinWidth="640"
        Style="{StaticResource OverlayWindow}"
        WindowStartupLocation="CenterScreen">
    <Border Background="Transparent" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (matches AI Models & Personas) -->
            <Border Grid.Row="0" Background="#3000D4FF" Padding="15,12" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="✏️ Edit System Prompt" FontSize="20" FontWeight="Bold" Foreground="#E0F7FF"/>
                        <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#B8E8F5" TextWrapping="Wrap">
                            <Run Text="Contact: "/>
                            <Run Text="{Binding ContactName, Mode=OneWay, FallbackValue='Unknown'}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕"
                            Width="32" Height="32"
                            Background="#40FF3366"
                            BorderThickness="0"
                            FontSize="16" FontWeight="Bold"
                            Foreground="#E0F7FF"
                            Cursor="Hand"
                            VerticalAlignment="Top"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#60FF3366"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content (no window-level ScrollViewer — avoids outer scrollbars) -->
            <Border Grid.Row="1" Background="#CC0A0E27" Padding="12">
                <Border Style="{StaticResource Card}" Margin="0" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🎙️ Voice &amp; behavior" FontSize="15" FontWeight="Bold"
                                   Foreground="#00D4FF" Margin="0,0,0,10"/>

                        <Border Grid.Row="1" Background="#300A0E27" BorderBrush="#4000D4FF" BorderThickness="1"
                                CornerRadius="5" Padding="12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="TTS voice (Piper)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E0F7FF" Margin="0,0,0,8"/>
                                <ComboBox Grid.Row="1"
                                          ItemsSource="{Binding AvailablePiperVoices}"
                                          Text="{Binding PiperVoiceId, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Background="#252F3F" BorderBrush="#4000D4FF" BorderThickness="1"
                                          Foreground="#E0F7FF" Padding="8"/>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="2" Text="👤 Avatar (virtual environment)" FontSize="15" FontWeight="Bold"
                                   Foreground="#00D4FF" Margin="0,0,0,8"/>

                        <Border Grid.Row="3" Background="#300A0E27" BorderBrush="#4000D4FF" BorderThickness="1"
                                CornerRadius="5" Padding="12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="3D Model Path:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding AvatarModelPath, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#252F3F" BorderBrush="#4000D4FF" BorderThickness="1"
                                             Foreground="#E0F7FF" Padding="8"/>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Voice Speed:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0.1" Maximum="3.0" Value="{Binding AvatarVoiceSpeed}"
                                            TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="5,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AvatarVoiceSpeed, StringFormat='{}{0:F1}'}"
                                               Foreground="#80C4D4" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Voice Pitch:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0.1" Maximum="3.0" Value="{Binding AvatarVoicePitch}"
                                            TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="5,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AvatarVoicePitch, StringFormat='{}{0:F1}'}"
                                               Foreground="#80C4D4" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="4" Text="System prompt" FontSize="15" FontWeight="Bold"
                                   Foreground="#00D4FF" Margin="0,0,0,8"/>

                        <TextBox Grid.Row="5"
                                 Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="260"
                                 VerticalAlignment="Stretch"
                                 Background="#0B1220" BorderBrush="#4000D4FF" BorderThickness="1"
                                 Foreground="#E0F7FF" Padding="10"
                                 FontFamily="Consolas" FontSize="12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"/>

                        <TextBlock Grid.Row="6"
                                   Text="Defines how this AI contact behaves. Long lines wrap; scroll inside this box if needed."
                                   FontSize="11" Foreground="#80C4D4"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#141B2E" Padding="14,12" CornerRadius="0,0,8,8"
                    BorderBrush="#4000D4FF" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GlassButton}" Content="💾 Save"
                            Width="120" Height="36" Margin="0,0,10,0"
                            Click="SaveButton_Click"/>
                    <Button Style="{StaticResource GlassButton}" Content="Cancel"
                            Width="120" Height="36"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
