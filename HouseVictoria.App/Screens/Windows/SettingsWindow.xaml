<Window x:Class="HouseVictoria.App.Screens.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:HouseVictoria.App.Converters"
        mc:Ignorable="d"
        Title="Settings" Height="1000" Width="1200"
        Style="{StaticResource OverlayWindow}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Border Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#3000D4FF" Padding="15,10" CornerRadius="6,6,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <TextBlock Text="⚙️ Configuration Settings" FontSize="20" FontWeight="Bold" Foreground="#E0F7FF"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Content="−" 
                               Width="30" Height="30" 
                               Background="#4000D4FF" 
                               BorderThickness="0"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#E0F7FF"
                               Cursor="Hand"
                               Margin="0,0,5,0"
                               Click="MinimizeButton_Click"
                               ToolTip="Minimize to Tray">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                       CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                     VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#6000D4FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="✕" 
                               Width="30" Height="30" 
                               Background="#40FF3366" 
                               BorderThickness="0"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#E0F7FF"
                               Cursor="Hand"
                               Click="CloseButton_Click"
                               ToolTip="Close">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                       CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                     VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#60FF3366"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Settings Categories (scrollable) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                <StackPanel>
                    <!-- SMS/MMS Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="📱 SMS/MMS Communication" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock Text="Configure SMS and MMS settings" FontSize="12" Foreground="#80C4D4"/>
                        </StackPanel>
                    </Border>

                    <!-- MCP Server Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🔌 MCP Server" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MCPServerEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding MCPServerConnectionStatus}" 
                                          VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding MCPServerConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MCPServerConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MCPServerConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="3" Content="Test" Style="{StaticResource GlassButton}" 
                                       Command="{Binding TestMCPConnectionCommand}" 
                                       Width="80" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- TTS / STT Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🔊 Text-to-Speech &amp; Speech-to-Text" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TTS Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding TTSEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding TTSConnectionStatus}" 
                                          Foreground="#00FF88" 
                                          VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding TTSConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TTSConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TTSConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="3" Content="Test" Style="{StaticResource GlassButton}" 
                                       Command="{Binding TestTTSConnectionCommand}" 
                                       Width="80" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="STT Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding STTEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding STTConnectionStatus}" 
                                          Foreground="#00FF88" 
                                          VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding STTConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding STTConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding STTConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="3" Content="Test" Style="{StaticResource GlassButton}" 
                                       Command="{Binding TestSTTConnectionCommand}" 
                                       Width="80" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>
                            <!-- Kokoro TTS Server (port 8880): start/stop -->
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Kokoro TTS Server:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding KokoroTTSStatus}" Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                                <Button Grid.Column="2" Content="Start Kokoro" Style="{StaticResource GlassButton}" 
                                       Command="{Binding StartKokoroCommand}" Width="110" Margin="5,0"/>
                                <Button Grid.Column="3" Content="Stop Kokoro" Style="{StaticResource GlassButton}" 
                                       Command="{Binding StopKokoroCommand}" Width="110" Margin="5,0"/>
                            </Grid>
                            <TextBlock Text="Kokoro TTS runs on http://localhost:8880. Set TTS Endpoint above to this URL to use Kokoro. Start/stop also available in System Monitor tray." 
                                      FontSize="11" Foreground="#5A6A7A" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Image Generation Endpoint (ComfyUI) -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🎨 Image Generation (ComfyUI)" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock Text="Configure the image generation endpoint (typically a local ComfyUI server)." FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding StableDiffusionEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding StableDiffusionConnectionStatus}" 
                                          VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding StableDiffusionConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StableDiffusionConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StableDiffusionConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="3" Content="Test" Style="{StaticResource GlassButton}" 
                                       Command="{Binding TestStableDiffusionConnectionCommand}" 
                                       Width="80" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>
                            <TextBlock Text="Default: http://localhost:8188 (ComfyUI)" 
                                      FontSize="11" Foreground="#5A6A7A" Margin="0,5,0,0" FontStyle="Italic"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Custom workflow:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ComfyUICustomWorkflowPath, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <Button Grid.Column="2" Content="Browse" Style="{StaticResource GlassButton}" 
                                       Command="{Binding BrowseComfyUICustomWorkflowPathCommand}" Width="70" Margin="5,0"/>
                            </Grid>
                            <TextBlock Text="Optional: Path to custom workflow JSON (ComfyUI API format). Use placeholders {{positive}}, {{negative}}, {{width}}, {{height}}, {{seed}}, {{filename_prefix}}."
                                      FontSize="11" Foreground="#5A6A7A" Margin="0,3,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Stability Matrix & ComfyUI (image/video generation) -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🖼️ Stability Matrix &amp; ComfyUI" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock Text="Start Stability Matrix and ComfyUI portable for image and video generation. Set the endpoint above to http://localhost:8188 when using ComfyUI." FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Margin="0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Stability Matrix:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StabilityMatrixPath, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Browse" Style="{StaticResource GlassButton}" 
                                       Command="{Binding BrowseStabilityMatrixPathCommand}" Width="70" Margin="5,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="ComfyUI folder:" Foreground="#E0F7FF" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ComfyUIPortablePath, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,8,5,0"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Browse" Style="{StaticResource GlassButton}" 
                                       Command="{Binding BrowseComfyUIPortablePathCommand}" Width="70" Margin="5,8,5,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Start Stability Matrix" Style="{StaticResource GlassButton}" 
                                       Command="{Binding StartStabilityMatrixCommand}" Margin="0,0,10,0"/>
                                <Button Content="Start ComfyUI" Style="{StaticResource GlassButton}" 
                                       Command="{Binding StartComfyUICommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Tools Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🛠️ Tools" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock Text="Configure available AI tools and functions" FontSize="12" Foreground="#80C4D4"/>
                        </StackPanel>
                    </Border>

                    <!-- Virtual Environment Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🌐 Virtual Environment (Unreal Engine)" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding UnrealEngineEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding UnrealConnectionStatus}" 
                                          Foreground="#00FF88" 
                                          VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding UnrealConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UnrealConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding UnrealConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="3" Content="Test" Style="{StaticResource GlassButton}" 
                                       Command="{Binding TestUnrealConnectionCommand}" 
                                       Width="80" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>
                            <TextBlock Text="Configure avatar locomotion, physical interactions, and virtual world settings" 
                                      FontSize="12" Foreground="#80C4D4" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Remote companion: phone → PC (text + audio); TLS at edge (tunnel). Restart app after changing. -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="📱 Remote companion (phone → PC)" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#80C4D4" Margin="0,0,0,8"
                                      Text="HTTP API on this PC for text chat and optional voice (STT on PC). Bind to loopback and use Tailscale / Cloudflare Tunnel for secure remote access. Video can be added later. Restart House Victoria after enabling or changing port/token."/>
                            <CheckBox IsChecked="{Binding RemoteCompanionEnabled}" Foreground="#E0F7FF" Margin="0,2"
                                     Content="Enable remote companion API"/>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Listen port:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding RemoteCompanionListenPort, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#252F3F" BorderBrush="#4000D4FF" Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="API token:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding RemoteCompanionApiToken, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#252F3F" BorderBrush="#4000D4FF" Foreground="#E0F7FF" Padding="8" Margin="5,0"
                                        ToolTip="Use at least 16 characters. Send as Authorization: Bearer &lt;token&gt; or X-Api-Key header."/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="AI contact ID:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding RemoteCompanionAiContactId, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#252F3F" BorderBrush="#4000D4FF" Foreground="#E0F7FF" Padding="8" Margin="5,0"
                                        ToolTip="Optional. Leave empty to use the primary AI contact."/>
                            </Grid>
                            <CheckBox IsChecked="{Binding RemoteCompanionListenOnLan}" Foreground="#E0F7FF" Margin="0,4"
                                     Content="Listen on all interfaces (LAN) — off = loopback only (safer with a tunnel)"/>
                            <CheckBox IsChecked="{Binding RemoteCompanionNotifyUnreal}" Foreground="#E0F7FF" Margin="0,2"
                                     Content="Notify Unreal after each reply (JSON command companion_remote_exchange)"/>
                        </StackPanel>
                    </Border>

                    <!-- LLM Servers: LM Studio, Ollama, Anything LLM (single block, one primary) -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🧠 LLM Servers" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock Text="Configure LM Studio, Ollama, and Anything LLM. Only one can be primary. Non-primary servers are not auto-started with the app; start them manually from the System Monitor drawer." 
                                      FontSize="11" Foreground="#80C4D4" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <!-- LM Studio -->
                            <TextBlock Text="LM Studio" FontSize="12" Foreground="#00D4FF" FontWeight="SemiBold" Margin="0,5,0,2"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding LmStudioEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding LmStudioConnectionStatus}" 
                                          Foreground="#00FF88" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding LmStudioConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LmStudioConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LmStudioConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding UseLmStudioAsPrimary}" 
                                             Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"
                                             ToolTip="Use as primary LLM. Uncheck current primary before selecting another."/>
                                    <Button Content="Test" Style="{StaticResource GlassButton}" 
                                           Command="{Binding TestLmStudioConnectionCommand}" 
                                           Width="60" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>
                            </Grid>
                            <!-- Ollama -->
                            <TextBlock Text="Ollama" FontSize="12" Foreground="#00D4FF" FontWeight="SemiBold" Margin="0,8,0,2"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding OllamaConnectionStatus}" 
                                          Foreground="#00FF88" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding OllamaConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OllamaConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OllamaConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding UseOllamaAsPrimary}" 
                                             Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"
                                             ToolTip="Use as primary LLM. Uncheck current primary before selecting another."/>
                                    <Button Content="Test" Style="{StaticResource GlassButton}" 
                                           Command="{Binding TestOllamaConnectionCommand}" 
                                           Width="60" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>
                            </Grid>
                            <!-- Anything LLM -->
                            <TextBlock Text="Anything LLM" FontSize="12" Foreground="#00D4FF" FontWeight="SemiBold" Margin="0,8,0,2"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding AnythingLLMEndpoint, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding AnythingLLMConnectionStatus}" 
                                          Foreground="#00FF88" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                          Visibility="{Binding AnythingLLMConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AnythingLLMConnectionStatus}" Value="✗ Failed">
                                                    <Setter Property="Foreground" Value="#FF3366"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AnythingLLMConnectionStatus}" Value="Testing...">
                                                    <Setter Property="Foreground" Value="#FFAA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding UseAnythingLLMAsPrimary}" 
                                             Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"
                                             ToolTip="Use as primary LLM. Uncheck current primary before selecting another."/>
                                    <Button Content="Test" Style="{StaticResource GlassButton}" 
                                           Command="{Binding TestAnythingLLMConnectionCommand}" 
                                           Width="60" Margin="5,0" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Color Scheme -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🎨 Color Scheme" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <TextBlock Text="Choose a color theme for the app. The preview shows how the selected theme will look." FontSize="12" Foreground="#80C4D4" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Theme:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" 
                                          ItemsSource="{Binding AvailableThemes}"
                                          SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          Background="#252F3F" Foreground="#E0F7FF"
                                          Padding="8" Margin="5,0"
                                          SelectionChanged="ThemeComboBox_SelectionChanged"/>
                            </Grid>
                            <TextBlock Text="Preview" FontSize="12" Foreground="#80C4D4" Margin="0,10,0,5"/>
                            <Border x:Name="ThemePreviewBorder" 
                                    MinHeight="140" CornerRadius="6" Padding="12"
                                    BorderThickness="1" Margin="0,0,0,5"
                                    Background="{DynamicResource DarkSurfaceBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Sample Title" FontSize="14" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="1" Text="Sample body text and secondary content" FontSize="11" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Border Background="{DynamicResource PrimaryBrush}" 
                                                CornerRadius="4" Padding="10,6" Margin="0,0,8,0"
                                                Opacity="0.8">
                                            <TextBlock Text="Button" FontSize="11" 
                                                       Foreground="{DynamicResource SelectionTextBrush}"/>
                                        </Border>
                                        <Border Background="{DynamicResource SuccessBrush}" 
                                                CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                                Opacity="0.9">
                                            <TextBlock Text="✓ Success" FontSize="10" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Border>
                                        <Border Background="{DynamicResource DarkInputBrush}" 
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="Input" FontSize="10" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Overlay Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🖥️ Overlay Settings" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Enable Overlay:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnableOverlay}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Overlay Opacity:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" Value="{Binding OverlayOpacity}" 
                                       TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Auto-Hide Trays:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding AutoHideTrays}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Auto-Hide Delay (ms):" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding AutoHideDelayMs, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Locomotion Settings -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🚶 Locomotion Settings" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Walk Speed:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <Slider Minimum="0.1" Maximum="10.0" Value="{Binding WalkSpeed}" 
                                           TickFrequency="0.1" IsSnapToTickEnabled="True"
                                           Foreground="#00D4FF" Background="#CC222222"/>
                                    <TextBlock Text="{Binding WalkSpeed, StringFormat='Speed: {0:F1}'}" 
                                             Foreground="#80C4D4" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Run Speed:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <Slider Minimum="0.1" Maximum="20.0" Value="{Binding RunSpeed}" 
                                           TickFrequency="0.1" IsSnapToTickEnabled="True"
                                           Foreground="#00D4FF" Background="#CC222222"/>
                                    <TextBlock Text="{Binding RunSpeed, StringFormat='Speed: {0:F1}'}" 
                                             Foreground="#80C4D4" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Jump Height:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <Slider Minimum="0.1" Maximum="10.0" Value="{Binding JumpHeight}" 
                                           TickFrequency="0.1" IsSnapToTickEnabled="True"
                                           Foreground="#00D4FF" Background="#CC222222"/>
                                    <TextBlock Text="{Binding JumpHeight, StringFormat='Height: {0:F1}'}" 
                                             Foreground="#80C4D4" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Enable Physics:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnablePhysicsInteraction}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Tools Configuration -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="🛠️ Tools Configuration" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="File System Access:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnableFileSystemAccess}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Network Access:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnableNetworkAccess}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="System Commands:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnableSystemCommands}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Persistent Memory Configuration -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="💾 Persistent Memory Configuration" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                            <Separator Margin="0,5" Background="#1A2332"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Enable Memory:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnablePersistentMemory}" 
                                         Foreground="#E0F7FF" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Memory Path:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PersistentMemoryPath, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max Entries:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MemoryMaxEntries, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Importance Threshold:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <Slider Minimum="0.0" Maximum="1.0" Value="{Binding MemoryImportanceThreshold}" 
                                           TickFrequency="0.1" IsSnapToTickEnabled="True"
                                           Foreground="#00D4FF" Background="#CC222222"/>
                                    <TextBlock Text="{Binding MemoryImportanceThreshold, StringFormat='Threshold: {0:F2}'}" 
                                             Foreground="#80C4D4" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Retention Days:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MemoryRetentionDays, UpdateSourceTrigger=PropertyChanged}" 
                                        Background="#252F3F" BorderBrush="#4000D4FF" 
                                        Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Separator Margin="0,12,0,8" Background="#4000D4FF"/>
                            <TextBlock Text="Semantic memory (Postgres + pgvector)" FontWeight="SemiBold" Foreground="#9CC7FF" Margin="0,0,0,4"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Enable pgvector:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EnablePgVector}" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Postgres connection:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PgVectorConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="Host=127.0.0.1;Port=5432;Database=housevictoria;Username=...;Password=..."
                                        Background="#252F3F" BorderBrush="#4000D4FF" Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Embedding model:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding OllamaEmbeddingModel, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="Ollama model for /api/embed (e.g. nomic-embed-text). Pull with: ollama pull nomic-embed-text"
                                        Background="#252F3F" BorderBrush="#4000D4FF" Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Vector dimensions:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding EmbeddingVectorDimensions, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="Must match the embedding model (768 for nomic-embed-text)."
                                        Background="#252F3F" BorderBrush="#4000D4FF" Foreground="#E0F7FF" Padding="8" Margin="5,0"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Hybrid lexical weight:" Foreground="#E0F7FF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="5,0">
                                    <Slider Minimum="0" Maximum="1" Value="{Binding HybridLexicalWeight}" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                           Foreground="#00D4FF" Background="#CC222222"/>
                                    <TextBlock Text="{Binding HybridLexicalWeight, StringFormat='Lexical weight: {0:F2} (vector = 1 − this)'}" Foreground="#80C4D4" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Validation Error Display -->
                    <Border Style="{StaticResource Card}" Margin="0,5" Background="#33FF3366" BorderBrush="#FF3366" BorderThickness="1"
                           Visibility="{Binding ValidationError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Margin="10">
                            <TextBlock Text="⚠️ Validation Error" FontSize="14" FontWeight="Bold" Foreground="#FF3366"/>
                            <TextBlock Text="{Binding ValidationError}" Foreground="#E0F7FF" TextWrapping="Wrap" Margin="0,5,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="MaxHeight" Value="60"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="MaxHeight" Value="300"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Connection Test Result Display -->
                    <Border Style="{StaticResource Card}" Margin="0,5" 
                           Background="#3300FF88" BorderBrush="#00FF88" BorderThickness="1"
                           Visibility="{Binding ConnectionTestResult, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Margin="10">
                            <TextBlock Text="{Binding ConnectionTestResult}" Foreground="#E0F7FF" FontSize="12" FontWeight="Bold" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="MaxHeight" Value="60"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="MaxHeight" Value="300"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <Border Style="{StaticResource Card}" Margin="0,5">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,10">
                                <Button Style="{StaticResource GlassButton}" 
                                       Content="🔄 Reset" 
                                       Command="{Binding ResetToDefaultsCommand}"
                                       Width="120" Height="35" Margin="0,0,10,0"
                                       ToolTip="Reset all settings to default values"/>
                                <Button Style="{StaticResource GlassButton}" 
                                       Content="📥 Import" 
                                       Command="{Binding ImportSettingsCommand}"
                                       Width="120" Height="35" Margin="0,0,10,0"/>
                                <Button Style="{StaticResource GlassButton}" 
                                       Content="📤 Export" 
                                       Command="{Binding ExportSettingsCommand}"
                                       Width="120" Height="35" Margin="0,0,10,0"/>
                                <Button Style="{StaticResource GlassButton}" 
                                       Content="💾 Save Settings" 
                                       Click="SaveButton_Click"
                                       Width="200" Height="35"
                                       IsEnabled="{Binding IsValid}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>

</Window>
