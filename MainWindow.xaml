<Window
    x:Class="LLMOD.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:LLMOD.SystemMonitorViewModels"
    Title="LLMOD DOCK"
    Width="70"
    Height="Auto"
    AllowsTransparency="True"
    Background="Transparent"
    Loaded="Window_Loaded"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">



    <!--  Industrial Glass Container  -->
    <Border
        Background="#CC141414"
        BorderBrush="#6600FFAA"
        BorderThickness="1">

        <Border.Effect>
            <DropShadowEffect
                BlurRadius="10"
                Direction="310"
                Opacity="0.6"
                ShadowDepth="4"
                Color="Black" />
        </Border.Effect>

        <!--  3 Equal Rows for Perfect Spacing  -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ROW 1: CHAT  -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <Button
                    Margin="10,0,10,0"
                    Padding="0"
                    Click="OpenChat_Click"
                    Content="💬"
                    FontSize="32"
                    FontWeight="Light"
                    ToolTip="Toggle LLMOD Interface">
                    <Button.Style>
                        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentColor}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3300FFAA" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--  Separator Line  -->
                <Border
                    Height="1"
                    Margin="10,5,10,0"
                    VerticalAlignment="Bottom"
                    Background="#66000000" />
            </StackPanel>

            <!--  ROW 2: SETTINGS (Opens System Monitor)  -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Button
                    Margin="10,0,10,0"
                    Padding="0"
                    Click="OpenSettings_Click"
                    Content="⏱"
                    FontSize="28"
                    ToolTip="System Monitor">
                    <Button.Style>
                        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#FF00FFAA" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3300FFAA" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!--  Separator Line  -->
                <Border
                    Height="1"
                    Margin="10,5,10,0"
                    VerticalAlignment="Bottom"
                    Background="#66000000" />
            </StackPanel>

            <!--  ROW 3: LLM CONFIG  -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <Button
                    Margin="10,0,10,0"
                    Padding="0"
                    Click="OpenSetup_Click"
                    Content="🔧"
                    FontSize="24"
                    ToolTip="LLM Database">
                    <Button.Style>
                        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#FF00FFAA" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3300FFAA" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>