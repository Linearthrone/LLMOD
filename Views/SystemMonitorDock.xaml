<Window
    x:Class="LLMOD.Views.SystemMonitorDock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LLMOD.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SystemMonitorDock"
    Width="64"
    Height="52"
    AllowsTransparency="True"
    Background="Transparent"
    Loaded="Window_Loaded"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border
        Background="#DD141414"
        BorderBrush="#6600FFAA"
        BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="10"
                Direction="310"
                Opacity="0.6"
                ShadowDepth="4"
                Color="Black"/>
        </Border.Effect>

        <Grid>
        <Button
            x:Name="MonitorButton"
            Width="58"
            Height="46"
            Margin="3"
            Padding="0"
            Click="Toggle_Click"
            ToolTip="System Monitor">
            <Button.Style>
                <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#3300FFAA"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3300FFAA"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>

            <!--  Modern Futuristic Computer Icon  -->
            <Viewbox Width="40" Height="40" Stretch="Uniform">
                <Canvas Width="64" Height="64">
                    <!--  Monitor Screen Frame  -->
                    <Path Data="M4 8h56a2 2 0 0 1 2 2v32a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2z" 
                          Fill="#1a1a1a" Stroke="#00FFAA" StrokeThickness="2" />
                    
                    <!--  Glassy Screen Reflection  -->
                    <Path Data="M4 10h56v26H4z" Fill="#00FFAA" Opacity="0.08" />
                    
                    <!--  Screen Glow Effect (inner)  -->
                    <Path Data="M6 12h52v22H6z" Fill="#00FFAA" Opacity="0.05" />
                    
                    <!--  Inner UI Elements (futuristic interface)  -->
                    <Path Data="M6 16h28v2H6zM6 20h18v2H6zM6 24h24v2H6zM6 28h14v2H6z" Fill="#00FFAA" Opacity="0.6" />
                    
                    <!--  Status Indicators  -->
                    <Ellipse Canvas.Left="38" Canvas.Top="28" Width="6" Height="6" Fill="#00FFAA">
                        <Ellipse.Effect>
                            <BlurEffect Radius="2"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Canvas.Left="46" Canvas.Top="28" Width="6" Height="6" Fill="#00FFAA" Opacity="0.7">
                        <Ellipse.Effect>
                            <BlurEffect Radius="2"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    
                    <!--  Monitor Stand  -->
                    <Path Data="M28 44h8l2 4h-12z" Fill="#1a1a1a" Stroke="#00FFAA" StrokeThickness="1.5" />
                    <Path Data="M22 48h20l1 2H21z" Fill="#1a1a1a" Stroke="#00FFAA" StrokeThickness="1.5" />
                    
                    <!--  Decorative Tech Lines  -->
                    <Path Data="M4 8V8" Stroke="#00FFAA" StrokeThickness="1" Canvas.Left="0" Canvas.Top="6"/>
                    <Path Data="M60 8V8" Stroke="#00FFAA" StrokeThickness="1" Canvas.Left="56" Canvas.Top="6"/>
                    <Line X1="2" Y1="4" X2="10" Y2="4" Stroke="#00FFAA" StrokeThickness="1" StrokeDashArray="2,2" Opacity="0.6"/>
                    <Line X1="54" Y1="4" X2="62" Y2="4" Stroke="#00FFAA" StrokeThickness="1" StrokeDashArray="2,2" Opacity="0.6"/>
                    
                    <!--  Corner Accents (cyberpunk style)  -->
                    <Path Data="M4 10v-4h4" Stroke="#00FFAA" StrokeThickness="1.5"/>
                    <Path Data="M60 10v-4h-4" Stroke="#00FFAA" StrokeThickness="1.5"/>
                </Canvas>
            </Viewbox>
        </Button>
        </Grid>
    </Border>
</Window>
