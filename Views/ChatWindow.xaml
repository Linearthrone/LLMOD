<Window
    x:Class="LLMOD.Views.ChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LLMOD COMMS"
    Height="Auto"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="ChatWindow_Deactivated"
    Loaded="ChatWindow_Loaded"
    Topmost="True"
    WindowStyle="None">

    <Window.DataContext>
        <vm:ChatViewModel xmlns:vm="clr-namespace:LLMOD.SystemMonitorViewModels" />
    </Window.DataContext>

    <Border Background="{DynamicResource ChatTint}" Style="{StaticResource LLMOD_Border}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Border
                Grid.Row="0"
                Padding="10"
                Background="#111"
                BorderBrush="#00FFAA"
                BorderThickness="0,0,0,1">
                <!--  FIX: Replaced invalid HorizontalAlignment="SpaceBetween" with a Grid for spacing  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontFamily="Consolas"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AccentColor}"
                        Text="LLMOD // CONNECTED" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="10"
                        Foreground="#00FF00"
                        Text="LIVE FEED" />
                </Grid>
            </Border>

            <!--  Chat Stream  -->
            <ScrollViewer
                Grid.Row="1"
                Margin="10"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <!--  User Bubble  -->
                                <Border
                                    x:Name="UserBubble"
                                    MaxWidth="500"
                                    Padding="10,6"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource UserBubble}"
                                    BorderBrush="#004444"
                                    BorderThickness="1"
                                    CornerRadius="0">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="White"
                                            Text="{Binding Content}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            HorizontalAlignment="Right"
                                            FontSize="9"
                                            Foreground="#AAA"
                                            Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" />
                                    </StackPanel>
                                </Border>

                                <!--  AI Bubble  -->
                                <Border
                                    x:Name="AIBubble"
                                    MaxWidth="500"
                                    Padding="10,6"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource AIBubble}"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource AccentColor}"
                                            Text="{Binding Sender}" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#EEE"
                                            Text="{Binding Content}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Sender}" Value="User">
                                    <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Sender}" Value="User">
                                    <Setter TargetName="AIBubble" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Sender}" Value="LLMOD_Core">
                                    <Setter TargetName="UserBubble" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="AIBubble" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!--  Input Console  -->
            <Border
                Grid.Row="2"
                Padding="10"
                Background="#111"
                BorderBrush="#333"
                BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Padding="6"
                        VerticalAlignment="Center"
                        Background="#0A0A0A"
                        BorderBrush="#333"
                        FontFamily="Consolas"
                        Foreground="#EEFFEE"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />

                    <Button
                        Grid.Column="1"
                        Width="100"
                        Margin="8,0,0,0"
                        Command="{Binding SendMessageCommand}"
                        Content="TRANSMIT"
                        FontFamily="Consolas"
                        FontSize="11" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
